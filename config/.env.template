# SSH connection to the remote host that runs the bridge daemon.
VB_REMOTE_HOST=your-remote-host.example.edu
VB_REMOTE_USER=your_username

# virtuoso-bridge-lite remote daemon port and local forwarded port.
# Configure any non-default SSH port in your ~/.ssh/config entry for the host above.
VB_REMOTE_PORT=65081
VB_LOCAL_PORT=65082

# Absolute POSIX path on remote host where safe_*.il SKILL helpers live.
# Required by OceanWorker (throwaway OCEAN subprocesses for PSF dump).
# Must match the --remote-skill-dir passed to scripts.
VB_REMOTE_SKILL_DIR=/remote/path/to/virtuoso-agent/skill

# Optional bash snippet run on the remote host before throwaway OCEAN starts.
# Use this when non-interactive SSH does not inherit Cadence module/license env.
# Example:
# VB_OCEAN_INIT_CMD='eval "$(<modulecmd-path> sh load cadence/ic_23.1)"'
VB_OCEAN_INIT_CMD=

# LLM API keys (set the one you use, never commit this file).
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=
MIMO_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM provider: claude, gemini, kimi, minimax, openai, mimo, deepseek, ollama
DEFAULT_LLM=claude

# Ollama model name (if using Ollama)
OLLAMA_MODEL=llama3

# MiniMax (domestic China endpoint) — override base_url / model if needed.
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# OpenAI — defaults; override model per checkpoint (gpt-5.5 / gpt-5.4-mini etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5

# Xiaomi MiMo v2.5-pro — OpenAI-compatible token-plan endpoint.
# Matches the `tp-` prefix on MIMO_API_KEY. The legacy
# `api.xiaomimimo.com` host returns HTTP 401 against token-plan keys.
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# DeepSeek V4 (MoE, OpenAI-compat; pro + flash variants for cost-quality Pareto)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
