# =========================================================================
# Sensitive / personal artifacts — public repo, keep tight
# =========================================================================

# Claude / LLM chat history (may contain secrets, paths, conversation)
.chat_recent.jsonl

# Agent run artifacts
logs/*.log
logs/*.jsonl
logs/*.md
logs/*.sh
logs/*.il
logs/*.py
logs/*.pid
!logs/.gitkeep

# HSpice agent transcript logs — written by the run loop next to the
# spec being driven. Carry raw scrubbed-output for debugging; gitignored
# so they never end up in the public repo, allowlisted so the P0 gate
# doesn't trip on local artifacts.
config/logs/

# Quarantined foundry-audit artifacts (strict — never commit)
.quarantine/

# In-progress / scratch (may contain private PDK maps, etc.)
tmp/

# Local working output dirs (schematic dumps, spec scaffolds, misc runs).
out/
specs_work/

# Per-DUT spec markdowns — each developer drafts their own; the public
# repo only ships the LC_VCO references. Project-specific specs (and any
# *_spec.md draft tied to a current circuit) stay local.
config/delay_test_spec.md
config/matching_test_spec.md

# Historical draft-review doc (contains real usernames and host)
docs/stage0_draft_review.md

# Deployment guide with real SSH config / username
docs/*_deployment/

# Team review deliverables (per-incident artifacts)
reviews/

# Debug / probe SKILL scripts (hardcoded personal paths in comments)
skill/rev*.il
skill/stage0_*.il
skill/stage1_*.il

# Manual rollback snapshots — git history IS the rollback mechanism.
*.rollback

# =========================================================================
# Secrets
# =========================================================================
config/.env
config/.sync.local
*.key
*.pem
.ssh/

# PDK scrub pattern extension — real foundry tokens live here, never commit.
# Ship the sanitized config/hspice_scrub_patterns.template.yaml instead and
# have each dev copy it to *.private.yaml to fill in real values.
config/hspice_scrub_patterns.private.yaml
config/hspice_scrub_patterns.yaml

# =========================================================================
# Python
# =========================================================================
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# =========================================================================
# IDE / OS
# =========================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
